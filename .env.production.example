# .env.production.example — Copier en .env sur le VPS
# Ne jamais committer le vrai .env dans git

# === API Keys ===
FMP_API_KEY="VOTRE_CLE_FMP"
COINGECKO_API_KEY="VOTRE_CLE_COINGECKO"
NEWSAPI_API_KEY="VOTRE_CLE_NEWSAPI"

# === Base de données PostgreSQL ===
DATABASE_URL="postgresql://postgres:flo@localhost:5432/site_bourse"
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=flo
DB_NAME=site_bourse

# === Serveur ===
PORT=3001
NODE_ENV=production
